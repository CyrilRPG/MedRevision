          {
            "id": "UE5_tous_202",
            "num": "5",
            "question": "Toutes les propositions suivantes sont exactes, SAUF UNE, laquelle ?",
            "propositions": [
              {
                "letter": "A",
                "text": "La zone la plus importante quantitativement pour la réabsorption du sodium est \nle  tube contourné proximal."
              },
              {
                "letter": "B",
                "text": "La zone la plus importante qualitativement pour la régulation du bilan sodé est \nle  tube contourné proximal."
              },
              {
                "letter": "C",
                "text": "La zone la plus importante quantitativement pour la réabsorption d’eau est le \ntube  contourné proximal."
              },
              {
                "letter": "D",
                "text": "Le glucose est normalement réabsorbé en totalité dans le tube contourné proximal."
              },
              {
                "letter": "E",
                "text": "La zone la plus importante quantitativement pour la réabsorption du potassium est \nle  tube contourné proximal."
              }
            ],
            "answers": "B",
