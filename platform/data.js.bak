          {
            "id": "UE5_tous_200",
            "num": "10",
            "question": "Parmi les propositions suivantes concernant le bilan du \nsodium,  indiquez la réponse exacte :",
            "propositions": [
              {
                "letter": "A",
                "text": "Le facteur atrial natriurétique stimule le système \nrénine-angiotensine-aldostérone"
              },
              {
                "letter": "B",
                "text": "La majorité du sodium filtré est réabsorbée avant le canal collecteur"
              },
              {
                "letter": "C",
                "text": "L’aldostérone diminue la réabsorption rénale de sodium"
              },
              {
                "letter": "D",
                "text": "Le contenu en sodium échangeable du milieu extracellulaire détermine le \nvolume  intracellulaire"
              },
              {
                "letter": "E",
                "text": "Le rein adapte l’excrétion urinaire de sodium à la natrémie."
              }
            ],
            "answers": "B",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "le facteur atrial natriurétique (ANF) inhibe le SRAA (↓ rénine, ↓ aldostérone)"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": false,
                "text": "l’aldostérone augmente la réabsorption de Na⁺ (et augmente l’excrétion de K⁺)"
              },
              {
                "letter": "D",
                "correct": false,
                "text": "le sodium est le principal cation du secteur extracellulaire et le contenu en Na+ échangeable détermine le volume extracellulaire, pas intracellulaire"
              },
              {
                "letter": "E",
                "correct": false,
                "text": "le rein adapte l’excrétion de Na+ au volume extracellulaire, pas directement à la natrémie et la natrémie reflète surtout l’équilibre hydrique"
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "physio"
          },
          {
            "id": "UE5_tous_201",
