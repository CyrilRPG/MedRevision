                "correct": true,
                "text": ""
              },
              {
                "letter": "B",
                "correct": false,
                "text": "La fièvre est un signe clinique fréquent mais non spécifique d’une CIVD. Elle peut être due à une infection sous-jacente."
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "Une leucocytose peut être présente mais n’est pas un critère diagnostique de la CIVD."
              },
              {
                "letter": "E",
                "correct": false,
                "text": "L’anémie est fréquente mais non spécifique de la CIVD, elle peut être due à d’autres causes (hémorragie, hémolyse associée)."
              }
            ],
            "images": [],
            "raw_back": ""
          }
        ]
