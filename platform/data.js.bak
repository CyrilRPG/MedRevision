          {
            "id": "UE5_tous_47",
            "num": "5",
            "question": "A propos de la filtration glomérulaire, indiquez la ou les réponse(s) exacte(s) :",
            "propositions": [
              {
                "letter": "A",
                "text": "La filtration glomérulaire est un processus actif"
              },
              {
                "letter": "B",
                "text": "La concentration plasmatique de glucose dans l’artériole efférente du glomérule est \nidentique à la  concentration de glucose dans le filtrat glomérulaire"
              },
              {
                "letter": "C",
                "text": "La pression d’ultrafiltration est identique sur toute la longueur du capillaire glomérulaire"
              },
              {
                "letter": "D",
                "text": "La vasoconstriction de l’artériole efférente du glomérule (sans autre modification par \nailleurs) favorise  la filtration glomérulaire"
              },
              {
                "letter": "E",
                "text": "Une augmentation de pression sanguine dans l’artériole afférente du \nglomérule induit une  vasoconstriction « réflexe » de celle-ci."
              }
            ],
            "answers": "BDE",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "la filtration glomérulaire est un processus passif"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": false,
                "text": "elle diminue progressivement le long du capillaire glomérulaire, car la pression oncotique plasmatique augmente avec la filtration"
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": true,
                "text": ""
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "Sujets d'examen"
          },
          {
            "id": "UE5_tous_48",
            "num": "6",
            "question": "Parmi les circonstances suivantes, laquelle ou lesquelles limite(nt) la constitution du gradient \nosmotique interstitiel  corticopapillaire ?",
            "propositions": [
              {
                "letter": "A",
                "text": "Un hyperaldostéronisme secondaire"
              },
              {
                "letter": "B",
                "text": "Un régime strictement végétarien"
              },
              {
                "letter": "C",
                "text": "Un traitement par furosémide"
              },
              {
                "letter": "D",
                "text": "Un traitement par diurétique thiazidique"
              },
              {
                "letter": "E",
                "text": "Une hypersécrétion d’ADH."
              }
            ],
            "answers": "BC",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "l’aldostérone agit surtout au niveau du tube distal et du tube collecteur sur la réabsorption de Na⁺, mais n’altère pas significativement la formation du gradient médullaire"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "les thiazidiques agissent surtout sur le tube contourné distal et n’altèrent pas directement le mécanisme de multiplication à contre-courant"
              },
              {
                "letter": "E",
                "correct": false,
                "text": "l’ADH favorise au contraire l’utilisation et le maintien du gradient médullaire en augmentant la perméabilité à l’eau et à l’urée dans le tube collecteur"
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "Sujets d'examen"
          },
          {
            "id": "UE5_tous_49",
            "num": "7",
            "question": "Parmi les circonstances suivantes, laquelle ou lesquelles peut (peuvent) induire une polyurie \niso-osmotique au plasma ?",
            "propositions": [
              {
                "letter": "A",
                "text": "Un diabète insipide neurogénique"
              },
              {
                "letter": "B",
                "text": "Une acidose plasmatique"
              },
              {
                "letter": "C",
                "text": "Un diabète insipide néphrogénique"
              },
              {
                "letter": "D",
                "text": "Un diabète sucré mal équilibré avec une glycémie à 20 mmol/L"
              },
              {
                "letter": "E",
                "text": "Une insuffisance surrénale aiguë."
              }
            ],
            "answers": "D",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "il y a un déficit en ADH, ce qui entraîne une polyurie hypo-osmotique (urines très diluées)"
