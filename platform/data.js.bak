            "source_course": "physio"
          },
          {
            "id": "UE5_tous_214",
            "num": "19",
            "question": "A propos du rôle du rein dans l’équilibre acide-base, indiquez la ou \nles  proposition(s) exacte(s) :",
            "propositions": [
              {
                "letter": "A",
                "text": "L’essentiel des ions H+ produits quotidiennement par l’alimentation et \nle  métabolisme sont éliminés sous forme libre dans l’urine"
              },
              {
                "letter": "B",
                "text": "L’aldostérone diminue l’excrétion urinaire d’acides"
              },
              {
                "letter": "C",
                "text": "La réabsorption proximale de bicarbonates est couplée à la réabsorption \nde  sodium"
              },
              {
                "letter": "D",
                "text": "L’ammoniogénèse rénale est stimulée par l’acidose chronique"
              },
              {
                "letter": "E",
                "text": "L’acidité titrable diminue lorsque le pH de l’urine diminue."
              }
            ],
            "answers": "CD",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "la majorité des H⁺ est excrétée sous forme de tampon"
              },
              {
                "letter": "B",
                "correct": false,
                "text": "l’aldostérone stimule la sécrétion de H⁺ par les cellules intercalaires α du canal collecteur, donc augmente l’excrétion acide"
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "quand le pH de l’urine diminue, l’acidité titrable augmente, car plus de H⁺ est sécrété et tamponné ANNALES 2016 session 2"
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "physio"
          },
          {
            "id": "UE5_tous_215",
            "num": "7",
            "question": "Le principal mécanisme d’excrétion rénale d’acides est \n:",
            "propositions": [
              {
                "letter": "A",
                "text": "L’acidité titrable"
              },
              {
                "letter": "B",
                "text": "La réabsorption proximale de bicarbonates"
              },
              {
                "letter": "C",
                "text": "L’excrétion urinaire d’ions H+ sous forme libre"
              },
              {
                "letter": "D",
                "text": "L’excrétion d’ions ammonium (NH4+)"
              },
              {
                "letter": "E",
                "text": "L’excrétion d’acide paraaminohippurique (PAH)."
              }
            ],
            "answers": "D",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "l’acidité titrable (H⁺ tamponné par phosphate) participe à l’excrétion des acides mais ce n’est pas le principal mécanisme"
              },
              {
                "letter": "B",
                "correct": false,
                "text": "La réabsorption de HCO₃⁻ ne constitue pas une excrétion d’acide, elle permet seulement de préserver le bicarbonate"
              },
              {
                "letter": "C",
                "correct": false,
                "text": "l’excrétion de H⁺ libre est très faible (<5%) car le H⁺ est toujours tamponné dans l’urine"
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "le PAH est utilisé pour mesurer le débit sanguin rénal (DSR), pas pour excréter des H⁺"
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "physio"
          },
          {
            "id": "UE5_tous_216",
            "num": "17",
            "question": "A propos du rôle du rein dans l’équilibre acide-base, indiquez la ou \nles  propositions exactes :",
            "propositions": [
              {
                "letter": "A",
                "text": "L’essentiel des ions H+ produits quotidiennement par l’alimentation et \nle  métabolisme sont éliminés sous forme libre dans l’urine"
              },
              {
                "letter": "B",
                "text": "L’aldostérone diminue l’excrétion urinaire d’acides"
