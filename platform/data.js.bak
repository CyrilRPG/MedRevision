              },
              {
                "letter": "E",
                "text": "L’opsonisation d’une bactérie correspond à la fixation sur cette dernière de fractions du complément et/"
              }
            ],
            "answers": "ACE",
            "explanations": [
              {
                "letter": "A",
                "correct": true,
                "text": ""
