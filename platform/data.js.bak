                "text": "vers la maturation granulocytaire"
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "PN éosinophiles"
              }
            ],
