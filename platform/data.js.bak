              "cours_UE5_Explorations_fonctiennelles_renale_p19_i6.png",
              "cours_UE5_Explorations_fonctiennelles_renale_p19_i7.png",
              "cours_UE5_Explorations_fonctiennelles_renale_p19_i8.png",
