          {
            "id": "UE5_tous_213",
            "num": "32",
            "question": "A propos des bicarbonates (HCO3- ), indiquez la (les) \nproposition(s)  exacte(s) :",
            "propositions": [
              {
                "letter": "A",
                "text": "Ils constituent le principal tampon intracellulaire"
              },
              {
                "letter": "B",
                "text": "Ils sont librement filtrés par le rein"
              },
              {
                "letter": "C",
                "text": "Les bicarbonates filtrés sont principalement réabsorbés au niveau de l’anse \nde  Henlé"
              },
              {
                "letter": "D",
                "text": "Le transport maximal des bicarbonates par le tubule rénal est augmenté en \ncas  d’hypercapnie chronique"
              },
              {
                "letter": "E",
                "text": "La bicarbonaturie est habituellement nulle ou quasi-nulle."
              }
            ],
            "answers": "BDE",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "les bicarbonates sont le principal tampon extracellulaire"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": false,
                "text": "la majorité des bicarbonates filtrés (~80%) est réabsorbée dans le tube contourné proximal"
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": true,
                "text": "ANNALES 2018 session 2"
              }
            ],
            "images": [],
