              {
                "letter": "A",
                "correct": false,
                "text": "l’épididyme est une voie génitale extra-testiculaire"
              },
              {
                "letter": "B",
                "correct": false,
                "text": "L’épididyme possède un épithélium cylindrique pseudostratifié avec stéréocils"
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "les cellules possèdent des stéréocils (longues microvillosités non mobiles) et pas de cils vibratiles"
              },
              {
                "letter": "E",
