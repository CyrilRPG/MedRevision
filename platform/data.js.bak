          {
            "id": "UE6_hematopoiese_q16_4",
            "num": "16",
            "question": "Parmi les propositions suivantes, quelle est ou quelles sont la ou les \nproposition(s) exacte(s):",
            "propositions": [
              {
                "letter": "A",
