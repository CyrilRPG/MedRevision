          {
            "id": "UE6_tous_16",
            "num": "10",
            "question": "Concernant les éléments figurés du sang, quelle est la proposition exacte :",
            "propositions": [
              {
                "letter": "A",
                "text": "Les macrophages sont des cellules circulantes d’origine monocytaire"
              },
              {
                "letter": "B",
                "text": "La durée de vie des éléments figurés dans le sang est, de la plus courte à la plus \nlongue :Plaquettes > Polynucléaires Neutrophiles > Hématies"
              },
              {
                "letter": "C",
                "text": "Les leucocytes sont pour 50% circulants et 50% marginés"
              },
              {
                "letter": "D",
                "text": "Les cellules du sang sont régulièrement produites par un processus étroitement régulé \nappelé hématopoïèse"
              },
              {
                "letter": "E",
                "text": "Les érythrocytes sont les précurseurs des hématies"
              }
            ],
            "answers": "D",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "les monocytes sont des cellules circulantes (= circulent dans le sang). Ils peuvent se différencier en macrophage si besoin (pour la phagocytose)"
              },
              {
                "letter": "B",
                "correct": false,
                "text": "PNN (24h)< Plaquettes (7j)< Hématies (120j)"
              },
              {
                "letter": "C",
                "correct": false,
                "text": "PNN 45% circulants et 55% marginés"
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "érythrocytes = hématies = GR"
              }
            ],
