      "Thrombopénies et purpuras": {
        "name": "Thrombopénies et purpuras",
        "questions": [
          {
            "id": "UE6_Thrombopenies_et_purpuras_q3_0",
            "num": "3",
            "question": "Mme V 20 ans a des gingivorragies récentes, elle a des ecchymoses et un purpura \npétéchial des chevilles. La NFS montre: Leucocytes 6.6 G/L, Hémoglobine 11g/dL, VGM 86 \nfL, Plaquettes 10G/L, Polynucléaires Neutrophiles 3.5 G/ L, Lymphocytes 2 G/L, monocytes \n0.8 G/L, Polynuclaires éosinophiles 0.4 G/L. Quel diagnostic évoquez vous en première \nintention ?",
            "propositions": [
              {
                "letter": "A",
                "text": "Myélodysplasie"
              },
              {
                "letter": "B",
                "text": "Leucémie lymphoïde chronique"
              },
              {
                "letter": "C",
                "text": "Purpura thrombopénique immunologique"
              },
              {
                "letter": "D",
                "text": "Carence en vitamine B12 ou folates"
              },
              {
                "letter": "E",
                "text": "Leucémie aiguë"
              }
            ],
            "answers": "C",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "Une myélodysplasie entraîne généralement des cytopénies multiples"
              },
              {
                "letter": "B",
                "correct": false,
                "text": "Une LLC entraîne une hyperlymphocytose, ce qui n’est pas le cas ici."
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "Une carence en B12 donne plutôt une anémie macrocytaire"
              },
              {
                "letter": "E",
                "correct": false,
                "text": "La leucémie aiguë entraîne généralement une pancytopénie avec blastes circulants."
              }
            ],
            "images": [],
            "raw_back": ""
          },
          {
            "id": "UE6_Thrombopenies_et_purpuras_q6_1",
            "num": "6",
            "question": "Mme V, 20 ans est adressée aux urgences par son médecin traitant qu’elle a consulté pour \ndes épistaxis. Le médecin lui a fait faire une NFS et l’a appelée pour qu’elle se rende à \nl’hôpital parce qu’elle « n’a plus de plaquettes ». Que recherchez vous a l’examen clinique ?",
            "propositions": [
