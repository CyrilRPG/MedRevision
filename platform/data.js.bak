          {
            "num": "19",
            "question": "Concernant la régulation de la maturation granuleuse, quelle est (sont) la (les) proposition(s) exacte(s) ?",
            "propositions": [
              {
                "letter": "A",
                "text": "Le SCF (Stem Cell Factor) et l’interleukine 3 (IL-3) agissent sur les progéniteurs myéloïdes"
              },
              {
                "letter": "B",
                "text": "Le G-CSF agit pour orienter les cellules vers la maturation monocytaire"
              },
              {
                "letter": "C",
                "text": "La granulopoïèse normale permet de produire des polynucléaires matures en environ 10 jours"
              },
              {
                "letter": "D",
                "text": "La granulopoïèse est un processus multi-étape qui combine différenciation aux stades précoces et"
              },
              {
                "letter": "E",
                "text": "L’interleukine 5 (Il-5) est essentielle pour la maturation des polynucléaires basophiles"
              }
            ],
            "answers": "AC",
            "explanations": [
              {
                "letter": "A",
                "correct": true,
                "text": ""
              },
              {
                "letter": "B",
                "correct": false,
                "text": ""
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "prolifération aux stades de maturation terminale"
              },
              {
                "letter": "E",
                "correct": false,
                "text": "Le M-CSF agit sur la maturation monocytaire, il n'y a plus de prolifération des cellules matures, l'Il-5 agit sur la maturation des polynucléaires Eosinophiles et le SCF sur les Basophiles."
              }
            ],
