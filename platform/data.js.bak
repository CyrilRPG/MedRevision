          {
            "id": "UE5_tous_199",
            "num": "8",
            "question": "L’hyperaldostéronisme secondaire :",
            "propositions": [
              {
                "letter": "A",
                "text": "S’accompagne d’une activité rénine plasmatique faible ou nulle"
              },
              {
                "letter": "B",
                "text": "Peut contribuer à la formation d’oedèmes périphériques"
              },
              {
                "letter": "C",
