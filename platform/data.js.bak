              {
                "letter": "B",
                "correct": false,
                "text": "Un purpura thrombopénique immunologique entraîne des pétéchies et ecchymoses"
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "L’hémarthrose est caractéristique d’un déficit en facteur de coagulation (hémophilie)"
