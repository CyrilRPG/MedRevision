          {
            "id": "UE5_tous_177",
            "num": "13",
            "question": "A propos de l’autorégulation du débit sanguin rénal :",
            "propositions": [
              {
                "letter": "A",
                "text": "Le rétrocontrôle tubuloglomérulaire joue sur les résistances de l’artériole \neﬀérente du glomérule"
              },
              {
                "letter": "B",
                "text": "Le rétrocontrôle tubuloglomérulaire fait intervenir la libération d’adénosine \npar les cellules de la macula"
              },
              {
                "letter": "C",
                "text": "La mise en jeu du mécanisme myogénique induit une vasodilatation de \nl’artériole aﬀérente"
              },
              {
                "letter": "D",
                "text": "Le mécanisme myogénique est mis en jeu en cas de diminution de \npression dans l’artériole aﬀérente"
              },
              {
                "letter": "E",
                "text": "La mise en jeu du mécanisme myogénique induit une diminution du débit de \nfiltration glomérulaire"
              }
            ],
            "answers": "B",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "le TGF agit principalement sur l’artérielle afférente et non efférente pour réguler le débit sanguin et le DFG"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": false,
                "text": "le mécanisme myogénique correspond à la contraction réflexe des cellules musculaires lisses de l'artériole afférente en réponse à une augmentation de pression , il ne provoque donc pas de vasodilatation"
              },
              {
                "letter": "D",
                "correct": false,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "le mécanisme myogénique ne diminue pas le débit de filtration glomérulaire ; il ajuste automatiquement la résistance de l’artériole afférente pour maintenir le DFG stable, que la pression augmente ou diminue."
              }
            ],
