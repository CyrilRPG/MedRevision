          {
            "id": "UE5_tous_168",
            "num": "1",
            "question": "A propos des clairances rénales, indiquez la ou les proposition(s) exacte(s) :",
            "propositions": [
              {
                "letter": "A",
                "text": "La clairance rénale d'une substance est le débit massique de cette substance \nvirtuellement éliminé du plasma par le rein"
              },
              {
                "letter": "B",
                "text": "Une substance dont la clairance rénale est nulle est toujours filtrée puis \nentièrement réabsorbée par le tubule rénal."
              },
              {
                "letter": "C",
                "text": "Une substance dont la clairance rénale est nulle n'est jamais retrouvée dans les \nurines"
              },
              {
                "letter": "D",
                "text": "Une substance librement filtrée dont la clairance rénale est inférieure au débit de \nfiltration glomérulaire est obligatoirement réabsorbée au niveau du tubule rénal"
              },
              {
                "letter": "E",
                "text": "Une substance librement filtrée dont la clairance rénale est supérieure au débit de \nfiltration glomérulaire est obligatoirement réabsorbée au niveau du tubule rénal."
              }
            ],
            "answers": "CD",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": ""
              },
              {
                "letter": "B",
                "correct": false,
                "text": "si la substance n’est pas filtrée comme l’albumine par exemple sa clairance sera aussi nulle"
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "si clairance >DFG=> substance secrétée et pas réabsorbée"
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "physio"
          },
          {
            "id": "UE5_tous_169",
            "num": "10",
            "question": "A propos des compartiments liquidiens, indiquez la ou les propositions \nexactes:",
            "propositions": [
              {
                "letter": "A",
                "text": "L'inuline peut être utilisée pour mesurer précisément le volume plasmatique"
              },
              {
                "letter": "B",
                "text": "La concentration en cation Na+ du milieu interstitiel est légèrement inférieure à sa \nconcentration dans l'eau plasmatique"
              },
              {
                "letter": "C",
                "text": "La membrane cellulaire est peu perméable aux substances dissoutes \nhydrosolubles telles que les ions, les sucres et les acides aminés"
              },
              {
                "letter": "D",
                "text": "La paroi capillaire est peu perméable aux substances dissoutes hydrosolubles \ntelles que les ions, les sucres et les acides aminés"
              },
              {
                "letter": "E",
                "text": "Les mouvements d'eau entre compartiment extracellulaire et compartiment \nintracellulaire sont toujours passifs"
              }
            ],
            "answers": "BCE",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "l’inuline permet de mesurer le volume extracellulaire total et non le volume plasmatique"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
