      "Granulopoièse, Monocytopoièse, PNN": {
        "name": "Granulopoièse, Monocytopoièse, PNN",
        "questions": [
          {
            "id": "UE6_Granulopoiese_Monocytopoiese_PNN_q13_0",
            "num": "13",
            "question": "Concernant les propriétés des polynucléaires neutrophiles quelle est \nla proposition exacte :",
            "propositions": [
              {
                "letter": "A",
                "text": "La somme des PNN des compartiments circulant et marginé est supérieure à la quantité \nde PNN du compartiment de stockage médullaire"
              },
              {
                "letter": "B",
                "text": "La partie constante des anticorps peut se fixer sur un récepteur Fc exprimé par une \ncellule phagocytaire"
              },
              {
                "letter": "C",
                "text": "L’opsonisation bloque les récepteurs clés de la phase initiale de la phagocytose"
              },
              {
                "letter": "D",
                "text": "La myéloperoxydase est une enzyme clé pour la détersion et la cicatrisation du site \ninflammatoire"
              },
              {
                "letter": "E",
                "text": "Les PNN peuvent suivre une voie de différenciation supplémentaire qui leur confère une \nfonction de sécrétion d’anticorps"
              }
            ],
            "answers": "B",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "le stockage médullaire de PNN est supérieur"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": false,
                "text": "c’est le chimiotactisme qui le fait"
              },
              {
                "letter": "D",
                "correct": false,
                "text": "la myéloperoxydase sert à catalyser la destruction de l’agent pathogène (c’est la macrophage qui s’occupe de la détersion et de la cicatrisation)"
              },
              {
                "letter": "E",
                "correct": false,
                "text": "ce sont les lymphocytes qui sont capables de se différencier en plasmocytes capables de sécréter des anticorps"
              }
            ],
            "images": [],
            "raw_back": ""
          },
          {
            "id": "UE6_Granulopoiese_Monocytopoiese_PNN_q16_1",
            "num": "16",
            "question": "Concernant les propriétés des polynucléaires neutrophiles, quelle est ou quelles sont \nla ou les proposition(s) exacte(s) :",
            "propositions": [
              {
                "letter": "A",
                "text": "Les PNN reçoivent les signaux des chimiokines grâce à leurs récepteurs Fc"
              },
              {
