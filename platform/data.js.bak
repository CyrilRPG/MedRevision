              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": true,
                "text": "Réponses : BC"
              },
              {
                "letter": "A",
                "correct": false,
                "text": "La PAS nocturne moyenne doit être < 120 mmHg"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "La PAD moyenne doit être < 80 mmHg"
              },
              {
                "letter": "E",
                "correct": false,
                "text": "La PAD nocturne doit être < 70 mmHg"
              }
            ],
