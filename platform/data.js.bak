                "correct": false,
                "text": ""
              },
              {
                "letter": "B",
                "correct": true,
                "text": "la régulation fine du bilan sodé se fait surtout au tubule distal et canal collecteur, sous l’influence de l’aldostérone"
              },
              {
                "letter": "C",
                "correct": false,
                "text": ""
              },
