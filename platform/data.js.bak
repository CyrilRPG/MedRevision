          {
            "id": "UE5_tous_175",
            "num": "5",
            "question": "A propos de la filtration glomérulaire, indiquez la ou les \nréponse(s) exacte(s) :",
            "propositions": [
              {
                "letter": "A",
                "text": "La filtration glomérulaire est un processus actif"
              },
              {
                "letter": "B",
                "text": "La concentration plasmatique de glucose dans l’artériole eﬀérente du \nglomérule est identique à la concentration de glucose dans le filtrat \nglomérulaire"
              },
              {
                "letter": "C",
                "text": "La pression d’ultrafiltration est identique sur toute la longueur du capillaire \nglomérulaire"
              },
              {
                "letter": "D",
                "text": "La vasoconstriction de l’artériole eﬀérente du glomérule (sans autre \nmodification par ailleurs) favorise la filtration glomérulaire"
              },
              {
                "letter": "E",
                "text": "Une augmentation de pression sanguine dans l’artériole aﬀérente du \nglomérule induit une vasoconstriction « réflexe » de celle-ci."
              }
            ],
            "answers": "BDE",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "c’est un processus passif"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": false,
                "text": "la pression d’ultrafiltration diminue le long du capillaire glomérulaire"
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
