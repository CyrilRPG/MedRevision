                "text": "en période nocturne, PAS : 110-129 mmHg"
              },
              {
                "letter": "D",
                "text": "en période nocturne, PAD : 60-69 mmHg"
              },
              {
                "letter": "E",
                "text": "en moyenne sur 24h, PAS : 120-140 mmHg"
              }
            ],
            "answers": "",
            "explanations": [],
            "images": [],
            "raw_back": ""
          },
