          {
            "id": "UE5_tous_73",
            "num": "2",
            "question": "La patiente présente effectivement des signes francs de déshydratation extracellulaire. Vous \ndemandez un bilan  biologique sanguin et urinaire.En cas de déshydratation extracellulaire isolée, \nquelle est ou quelles sont la ou les  anomalie(s) plasmatique(s) attendue(s) ?",
            "propositions": [
              {
                "letter": "A",
                "text": "Taux d’hématocrite augmenté"
              },
              {
                "letter": "B",
                "text": "Natrémie augmentée"
              },
              {
                "letter": "C",
                "text": "Kaliémie augmentée"
              },
              {
                "letter": "D",
                "text": "Glycémie augmentée"
              },
              {
                "letter": "E",
                "text": "Protidémie abaissée"
              }
            ],
            "answers": "A",
            "explanations": [
              {
                "letter": "A",
                "correct": true,
                "text": ""
              },
              {
                "letter": "B",
                "correct": false,
                "text": "si la déshydratation est isotonique (extracellulaire), la natrémie reste normale. Une hypernatrémie serait attendue en cas de perte d’eau pure"
              },
              {
                "letter": "C",
                "correct": false,
                "text": "la kaliémie reste généralement normale sauf s’il y a dépenses urinaires ou déshydratation intracellulaire"
              },
              {
                "letter": "D",
                "correct": false,
                "text": "pas directement liée à la déshydratation extracellulaire isolée"
              },
              {
                "letter": "E",
                "correct": false,
                "text": "la protidémie peut augmenter légèrement par hémoconcentration, pas s’abaisser"
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "Sujets d'examen"
          },
          {
            "id": "UE5_tous_74",
