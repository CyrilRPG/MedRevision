          {
            "id": "UE6_tous_39",
            "num": "8",
            "question": "Concernant le temps d’occlusion plaquettaire (TOP), quelle(s) est (sont) la(les) \nproposition(s)  exacte(s) ?",
            "propositions": [
              {
                "letter": "A",
                "text": "Le TOP explore les plaquettes, le fibrinogène et le facteur Willebrand"
              },
