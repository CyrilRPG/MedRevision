          {
            "id": "UE5_tous_71",
            "num": "9",
            "question": "Concernant le détrusor, quelle(s) est(sont) la(les) proposition(s) exacte(s) ?",
            "propositions": [
              {
                "letter": "A",
                "text": "L'acétylcholine se fixant sur des récepteurs nicotiniques favorise sa contraction"
