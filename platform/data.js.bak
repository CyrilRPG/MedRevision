          {
            "id": "UE5_tous_220",
            "num": "17",
            "question": "Quelles sont les valeurs de pression artérielle normale chez un \nhomme de 20 ans ?",
            "propositions": [
              {
                "letter": "A",
                "text": "Pression artérielle systolique moyenne sur 24h : 135 mmHg"
              },
              {
                "letter": "B",
                "text": "Pression diastolique nocturne moyenne : 68 mmHg"
              },
              {
                "letter": "C",
                "text": "Pression artérielle systolique diurne moyenne : 130 mmHg"
              },
              {
                "letter": "D",
                "text": "Pression artérielle moyenne diastolique /24h : 75 mmHg"
              },
              {
                "letter": "E",
                "text": "Pression diastolique en consultation : 85 mmHg"
              }
            ],
            "answers": "CDE",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "la bandelette urinaire est négative si la coloration est due à une consommation de betterave"
              },
              {
                "letter": "B",
                "correct": false,
                "text": "dans le cas de la tumeur de la vessie on devrait retrouver des globules rouges à l’ECBU"
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": true,
                "text": "Réponses : BCDE"
              },
              {
                "letter": "A",
                "correct": false,
                "text": "PAS moyenne sur 24h doit être inférieure à 130 mmHg"
              },
              {
                "letter": "B",
                "correct": true,
                "text": "PAD nocturne moyenne doit être < 70 mmHg"
              },
              {
                "letter": "C",
                "correct": true,
                "text": "PAS diurne moyenne doit être < 135 mmHg"
              },
              {
                "letter": "D",
                "correct": true,
                "text": "PAD moyenne doit être < 80"
              },
              {
                "letter": "E",
                "correct": true,
                "text": "PAD en consultation doit être < 90 mmHg"
              }
            ],
            "images": [],
