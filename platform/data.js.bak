              {
                "letter": "D",
                "text": "Une antibiothérapie large spectre doit être instaurée."
              },
              {
                "letter": "E",
                "text": "Il peut s’agir d’une neutropénie ethnique."
              }
            ],
            "answers": "ACD",
            "explanations": [
              {
                "letter": "A",
