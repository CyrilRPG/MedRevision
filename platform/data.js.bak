          {
            "id": "UE5_tous_10",
            "num": "1",
            "question": "Parmi les propositions suivantes, indiquez la ou les proposition(s) exacte(s)",
            "propositions": [
              {
                "letter": "A",
                "text": "Le testicule est enveloppé d’une capsule conjonctive appelée l’albuginée"
              },
              {
                "letter": "B",
                "text": "Le testicule a une fonction uniquement exocrine"
              },
              {
                "letter": "C",
                "text": "Entre albuginée et corps d’Highmore sont tendues des cloisons radiaires ou septa"
              },
              {
                "letter": "D",
                "text": "A la naissance les testicules sont situés dans la région inguinale"
              },
              {
                "letter": "E",
                "text": "Les cellules de Sertoli se situent dans l’espace interstitiel"
              }
            ],
            "answers": "AC",
            "explanations": [
              {
                "letter": "A",
                "correct": true,
                "text": ""
              },
              {
                "letter": "B",
                "correct": false,
                "text": "Le testicule a une fonction exocrine (Spermatogenèse) et endocrine(Sécrétion d’androgènes)."
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "A la naissance les testicules sont situés dans le scrotum."
              },
              {
                "letter": "E",
                "correct": false,
                "text": "Les cellules de Sertoli se situent dans l’épithélium des tubes séminifères des testicules."
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "Histologie"
          },
          {
            "id": "UE5_tous_11",
            "num": "2",
            "question": "Quelle est la réponse exacte ?",
            "propositions": [
              {
                "letter": "A",
                "text": "L’épididyme est une voie intra-testiculaire"
              },
              {
                "letter": "B",
                "text": "L’épididyme a un épithélium cubique simple"
              },
              {
                "letter": "C",
                "text": "La partie terminale de l’épididyme est un lieu de stockage des spermatozoïdes"
              },
              {
                "letter": "D",
                "text": "La cellule de l’épithélium épididymaire est caractérisée par la présence de cils vibratiles"
              },
              {
                "letter": "E",
                "text": "La musculeuse de l’épididyme s’amincit progressivement de la tête à la queue avec une \norganisation en 1 couche dans sa partie terminale"
              }
            ],
            "answers": "C",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "L’épididyme est une voie extra-testiculaire."
              },
              {
                "letter": "B",
                "correct": false,
                "text": "L’épididyme a un épithélium prismatique pseudo-stratifié."
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "La cellule de l’épithélium épididymaire est caractérisée par la présence de stéréocils."
              },
              {
                "letter": "E",
                "correct": false,
                "text": "La musculeuse s’épaissit de la tête vers la queue"
              }
            ],
