          {
            "id": "UE5_tous_190",
            "num": "30",
            "question": "Parmi les situations suivantes, laquelle (lesquelles) peu(ven)t \ninduire  une hypokaliémie ?",
            "propositions": [
              {
                "letter": "A",
                "text": "Une insuffisance rénale chronique par réduction néphronique"
              },
              {
                "letter": "B",
                "text": "La prise de laxatifs"
              },
              {
                "letter": "C",
                "text": "Une rhabdomyolyse"
              },
              {
                "letter": "D",
                "text": "Une alcalose aiguë"
              },
              {
                "letter": "E",
                "text": "Une insuffisance surrénale aiguë"
              }
            ],
            "answers": "BD",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "L’insuffisance rénale chronique entraîne généralement une hyperkaliémie car la capacité d’excrétion du potassium est réduite"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": false,
                "text": "la rhabdomyolyse libère du K⁺ intracellulaire dans le plasma → hyperkaliémie"
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "l’insuffisance surrénale (déficit en aldostérone) entraîne une hyperkaliémie car la sécrétion rénale de K diminue."
              }
            ],
            "images": [],
            "raw_back": "",
            "source_course": "physio"
          },
          {
            "id": "UE5_tous_191",
