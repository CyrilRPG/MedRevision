        "questions": [
          {
            "id": "UE6_Anemie_normochrome_et_normo-macrocytaire_q4_0",
            "num": "4",
            "question": "Madame L, 75 ans, présente une asthénie depuis quelques semaines. Elle est pâle et \nessoufflée. La NFS montre une hémoglobine à 5.5 g/dL, les réticulocytes sont à 2 G/L. De \nquoi dépend la tolérance de l’anémie ?",
            "propositions": [
              {
                "letter": "A",
                "text": "De l’âge"
              },
              {
                "letter": "B",
                "text": "De l’état cardiaque"
              },
              {
                "letter": "C",
                "text": "De cytopénies associées"
              },
              {
                "letter": "D",
                "text": "De l’abondance"
              },
              {
                "letter": "E",
                "text": "De la rapidité d’installation"
              }
            ],
            "answers": "BE",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "L’âge seul ne définit pas la tolérance, c’est surtout l’état cardiovasculaire qui est déterminant."
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": false,
                "text": "Ce n’est pas un critère principal de tolérance de l’anémie."
              },
              {
                "letter": "D",
                "correct": false,
                "text": "Une anémie chronique bien tolérée peut être profonde sans retentissement aigu."
