          {
            "id": "UE5_tous_82",
            "num": "1",
            "question": "A propos de l’anatomie rénale, indiquez la ou les propositions exactes :",
            "propositions": [
              {
                "letter": "A",
                "text": "Les glomérules des néphrons profonds sont situés dans la médullaire \nrénale externe"
              },
              {
                "letter": "B",
                "text": "Chaque rein contient environ un million de néphrons"
              },
              {
                "letter": "C",
                "text": "Les tubules rénaux sont situés dans les pyramides de Malpighi"
              },
              {
                "letter": "D",
                "text": "La circulation sanguine rénale constitue un système parte artériel"
              },
              {
                "letter": "E",
                "text": "Les vasa recta irriguent les anses de Henlé des néphrons superficiels"
              }
            ],
            "answers": "BCD",
            "explanations": [
              {
                "letter": "A",
                "correct": false,
                "text": "les glomérules sont toujours situés dans le cortex rénal"
              },
              {
                "letter": "B",
                "correct": true,
                "text": ""
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": true,
                "text": ""
              },
              {
                "letter": "E",
                "correct": false,
                "text": "les vasa recta :irriguent la médullaire, accompagnent les anses de Henlé longues donc celles des néphrons juxta-médullaires (profonds)"
              }
            ],
