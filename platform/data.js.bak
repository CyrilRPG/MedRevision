              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "un pH de 7,60 = alcalose, qui entraîne généralement une hypokaliémie"
              },
              {
                "letter": "E",
                "correct": true,
                "text": ""
              }
            ],
