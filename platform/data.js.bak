          {
            "num": "1",
            "question": "Concernant la physiologie de la miction, sélectionnez les réponses exactes (5 réponses exactes attendues) :",
            "propositions": [
              {
                "letter": "A",
                "text": "La miction normale permet l’évacuation des urines sans résidu."
              },
              {
                "letter": "B",
                "text": "Le fonctionnement vésical comprend l’alternance de 3 phases : le remplissage, la continence et la"
              },
              {
                "letter": "C",
                "text": "Les centres médullaires sympathiques se situent au niveau de la moelle sacrée."
              },
              {
                "letter": "D",
                "text": "Le détrusor est un muscle lisse."
              },
              {
                "letter": "E",
                "text": "Le sphincter externe est un muscle lisse."
              },
              {
                "letter": "F",
                "text": "Le sphincter interne est innervé par le système nerveux somatique."
              },
              {
                "letter": "G",
                "text": "L’acétylcholine peut se fixer sur des récepteurs de type alpha ou beta."
              },
              {
                "letter": "H",
                "text": "L’innervation sensitive de la vessie est à l’origine de réflexes médullaires."
              },
              {
                "letter": "I",
                "text": "Le centre de la miction se situe au niveau du tronc cérébral."
              },
              {
                "letter": "J",
                "text": "En phase de continence, le cortex préfrontal inhibe le centre de la miction."
              },
              {
                "letter": "K",
                "text": "L’activation sympathique favorise la contraction du détrusor."
              },
              {
                "letter": "L",
                "text": "L’activation parasympathique favorise la contraction du sphincter interne."
              }
            ],
            "answers": "ADHIJ",
            "explanations": [
              {
