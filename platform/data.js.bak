              {
                "letter": "C",
                "text": "Le vWF protège le facteur VIII de la protéolyse plasmatique"
              },
              {
                "letter": "D",
                "text": "Un déficit en vWF n’impacte que l’hémostase primaire"
              },
              {
                "letter": "E",
                "text": "Le vWF est un facteur vitamine K-dépendant"
              }
            ],
            "answers": "ABC",
            "explanations": [
