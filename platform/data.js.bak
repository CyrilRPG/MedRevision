                "correct": false,
                "text": "c’est la M-CSF, le G-CSF : PNN"
              },
              {
                "letter": "C",
                "correct": true,
                "text": ""
              },
              {
                "letter": "D",
                "correct": false,
                "text": "plus de prolifération des cellules matures"
              },
              {
                "letter": "E",
                "correct": false,
